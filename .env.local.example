NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Legacy anon key still supported as fallback:
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Transaction pooler (IPv4-friendly). This project: aws-1-eu-north-1, port 6543.
# DATABASE_URL=postgresql://postgres.hgxihcjjtwzhamrpzwhb:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:6543/postgres
# Direct connection (IPv6-only on some networks — may fail from Node on Windows):
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.hgxihcjjtwzhamrpzwhb.supabase.co:5432/postgres

ADMIN_SECRET=change-me-to-a-long-random-string